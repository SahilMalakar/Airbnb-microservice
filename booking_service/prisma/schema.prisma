// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/infra/database/generated"
}

datasource db {
  provider = "postgresql"
}

model Booking {
  id Int @id @default(autoincrement())

  roomId        Int
  userId        Int
  hotelId       Int
  totalGuests   Int
  bookingAmount Int
  status        BookingStatus @default(PENDING)

  checkInDate  DateTime @db.Date
  checkOutDate DateTime @db.Date

  holdExpiresAt DateTime // when this PENDING hold dies if not confirmed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  idempotencyKeys IdempotencyKey[]

  @@index([roomId])
  @@index([userId])
  @@index([hotelId])
  @@index([roomId, checkInDate, checkOutDate])
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
}

model IdempotencyKey {
  id        Int      @id @default(autoincrement())
  key       String
  userId    Int
  finalized Boolean  @default(false)
  booking   Booking? @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookingId Int?

  @@unique([userId, key])
}

// act as a index db table to scan faster the room availability for a date range
model RoomAvailability {
  id Int @id @default(autoincrement())

  roomId Int

  date DateTime @db.Date

  totalCount  Int @default(1) // total available space/bed count in single room / hostel / apartment
  bookedCount Int @default(0) // increases only if payment/booking confirmed
  heldCount   Int @default(0) // increases when hold confirmed, decreases when confirmed or cancelled

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roomId, date])
  @@index([roomId, date])
}

// cache metadata for rooms
model RoomRef {
  roomId       Int      @id // same value as Hotel service's Room.id
  hotelId      Int // denormalized, useful for queries/reporting
  isActive     Boolean  @default(true) // false once RoomDeleted event received
  price        Int // denormalized snapshot, may drift — not source of truth
  maxOccupancy Int      @default(1)
  syncedAt     DateTime @updatedAt

  @@index([hotelId])
  @@index([isActive])
}

model Outbox {
  id               Int       @id @default(autoincrement())
  eventId          String    @default(uuid())
  eventType        String
  aggregateType    String    // (e.g. "Booking")
  aggregateId      Int
  aggregateVersion Int
  schemaVersion    Int       @default(1)
  payload          Json
  correlationId    String?
  occurredAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  processedAt      DateTime?
  @@index([processedAt])
}