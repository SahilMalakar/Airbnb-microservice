generator client {
  provider = "prisma-client"
  output   = "../src/infra/database/generated"
}

datasource db {
  provider = "postgresql"
}

model Hotel {
  id          Int    @id @default(autoincrement())
  name        String
  description String
  hostId      Int // reference to Auth service's User.id/host.id — not a real FK
  address     String
  pincode     String

  cityId Int
  city   City @relation(fields: [cityId], references: [id])

  stateId Int
  state   State @relation(fields: [stateId], references: [id])

  rooms Room[]
  // ratingSummary HotelRatingSummary?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([cityId])
  @@index([stateId])
  @@index([hostId])
}

model City {
  id   Int    @id @default(autoincrement())
  name String

  stateId Int
  state   State @relation(fields: [stateId], references: [id])

  hotels Hotel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([stateId])
}

model State {
  id   Int    @id @default(autoincrement())
  name String

  cities City[]
  hotels Hotel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoomCategory {
  id          Int      @id @default(autoincrement())
  roomType    RoomType // e.g. general / deluxe / suite
  description String

  rooms Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RoomType {
  STANDARD // cheapest — basic amenities, smallest room size
  DELUXE // mid-tier — more space, better view/amenities than Standard
  SUITE // most expensive — multiple rooms/living area, premium amenities
}

model Room {
  id     Int    @id @default(autoincrement())
  roomNo String
  price  Int

  hotelId Int
  hotel   Hotel @relation(fields: [hotelId], references: [id])

  roomCategoryId Int
  roomCategory   RoomCategory @relation(fields: [roomCategoryId], references: [id])
  maxOccupancy   Int @default(1)

  // no bookingId, no date_of_availability — booking history lives in Booking service

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([hotelId])
  @@index([roomCategoryId])
  @@unique([hotelId, roomNo])
}

